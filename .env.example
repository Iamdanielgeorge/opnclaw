# ===========================================
# ClaudeClaw Configuration
# ===========================================
# Copy this file to .env and fill in your values.
# Run: npm run setup (recommended — the wizard does this for you)

# --- Required ---

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID (send /chatid to the bot to get this)
ALLOWED_CHAT_ID=

# --- AI Provider ---

# Which AI backend to use: 'claude' (default) or 'openai'
# AI_PROVIDER=openai

# OpenAI API key (required when AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# OpenAI model (default: codex-5.4)
# OPENAI_MODEL=codex-5.4

# Max tokens for OpenAI responses (default: 4096)
# OPENAI_MAX_TOKENS=4096

# --- Voice (Groq STT) ---

# Free API key from https://console.groq.com
GROQ_API_KEY=

# --- Video Analysis ---

# Free API key from https://aistudio.google.com
GOOGLE_API_KEY=

# --- Voice TTS (optional, not currently enabled) ---

# API key from https://elevenlabs.io
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# --- Dashboard ---

# Enable web dashboard (default: true)
# DASHBOARD_ENABLED=true

# Dashboard port (default: 3333)
# DASHBOARD_PORT=3333

# --- Logging ---

# Log level: trace, debug, info, warn, error, fatal
# LOG_LEVEL=info
